class Solution {
public:
    bool isPalindrome(int x) {
        int rem =0,num =x ; 
        long long ans =0;
        while (x>0){
            rem = x%10;
            x =x/10;
            ans = ans * 10 + rem;
        }
        if (num == ans){
            return true;
        }
        else {
            return false;
        }        
    }
};